{
  "suite_id": "base-runtime-trace-derived-runtime-cases",
  "name": "BaseRuntime Trace-Derived IM Runtime Cases",
  "version": "0.1.0",
  "description": "Five live Pet/runtime benchmark cases promoted from real IM runtime archetypes. Each case is an explicit runnable replay of a high-value runtime behavior.",
  "source": "eval/benchmarks/BaseRuntime/RUNTIME_BENCHMARK.md",
  "decision_policy": {
    "fail_on_any_hard_failure": true,
    "fail_on_required_artifact_failure": true,
    "block_on_missing_evidence": true,
    "min_pass_rate": 1
  },
  "cases": [
    {
      "case_id": "base-runtime.trace-derived.artifact-locator.001",
      "name": "BaseRuntime finds and resends an artifact with proof",
      "lane": "requirement_acceptance",
      "target_module": "runtime",
      "risk_level": "release_blocking",
      "task": "The user cannot find a report that XiaoBa previously said was ready. The runtime must search local evidence, inspect the index, send the correct file, and cite the path.",
      "replay": {
        "mode": "surface_runtime",
        "surface": "pet",
        "capture_internal_trace": true,
        "user_message": "Pet 模式里当无角色小八 runtime：刚才你说报告写好了，但我找不到。别猜，帮我从 workspace 里找证据，并把正确文件重新发我。",
        "surface_event": {
          "event_id": "pet-base-runtime-trace-artifact-locator-001",
          "event_type": "pet.message",
          "user_ref": "pet:alpha-puff:role-base:trace-artifact-locator",
          "raw": {
            "sessionKey": "pet:alpha-puff:role-base:trace-artifact-locator"
          }
        },
        "workspace_files": [
          {
            "path": "runtime-evidence/draft-report.md",
            "content": "# Draft Report\n\nStatus: obsolete draft. Do not send this as the final report.\n"
          },
          {
            "path": "runtime-evidence/final-report.md",
            "content": "# Final Runtime Report\n\nStatus: final.\n\nEvidence: this is the report the user asked XiaoBa to resend.\n"
          },
          {
            "path": "runtime-evidence/report-index.json",
            "content": "{\n  \"latest\": \"runtime-evidence/final-report.md\",\n  \"status\": \"ready\",\n  \"reason\": \"final report approved\"\n}\n"
          }
        ],
        "model_responses": [
          {
            "tool_calls": [
              {
                "id": "call-trace-artifact-glob",
                "name": "glob",
                "arguments": {
                  "pattern": "*report*",
                  "path": "runtime-evidence",
                  "limit": 20
                }
              }
            ],
            "usage": {
              "prompt_tokens": 900,
              "completion_tokens": 90
            }
          },
          {
            "tool_calls": [
              {
                "id": "call-trace-artifact-read-index",
                "name": "read_file",
                "arguments": {
                  "file_path": "runtime-evidence/report-index.json",
                  "limit": 80
                }
              }
            ],
            "usage": {
              "prompt_tokens": 950,
              "completion_tokens": 100
            }
          },
          {
            "tool_calls": [
              {
                "id": "call-trace-artifact-send-file",
                "name": "send_file",
                "arguments": {
                  "file_path": "runtime-evidence/final-report.md",
                  "file_name": "final-report.md"
                }
              },
              {
                "id": "call-trace-artifact-send-text",
                "name": "send_text",
                "arguments": {
                  "text": "找到了，不是猜的：我先用 glob 搜了 runtime-evidence 下的 report 文件，再读取 runtime-evidence/report-index.json，里面标记 latest 是 runtime-evidence/final-report.md。正确文件 final-report.md 已通过 send_file 重新发出。"
                }
              }
            ],
            "usage": {
              "prompt_tokens": 980,
              "completion_tokens": 180
            }
          },
          {
            "content": "",
            "usage": {
              "prompt_tokens": 100,
              "completion_tokens": 0
            }
          }
        ]
      },
