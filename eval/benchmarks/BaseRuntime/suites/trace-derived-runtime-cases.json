              "runtime-evidence/report-index.json",
              "final-report.md"
            ],
            "required_files": [
              "final-report.md"
            ]
          }
        },
        {
          "id": "artifact_evidence",
          "config": {
            "require_manifest_evidence": true
          }
        },
        {
          "id": "tool_sequence",
          "config": {
            "names": [
              "glob",
              "read_file",
              "send_file",
              "send_text"
            ],
            "exact": true
          }
        },
        {
          "id": "assistant_text_contains",
          "config": {
            "include_delivery_tools": true,
            "texts": [
              "glob",
              "runtime-evidence/report-index.json",
              "runtime-evidence/final-report.md",
              "send_file"
            ],
            "forbidden_texts": [
              "我猜",
              "应该在"
            ]
          }
        },
        {
          "id": "budget_check",
          "config": {
            "max_turns": 3,
            "max_tool_calls": 4,
            "max_tokens": 7000
          }
        }
      ],
      "required_artifacts": [
        {
          "path": "runtime-evidence/final-report.md",
          "type": "md",
          "evidence": "manifest",
          "must_exist": true
        }
      ],
      "failure_route": "runtime"
    },
