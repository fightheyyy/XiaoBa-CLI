{
  "suite_id": "contract-sentinel",
  "name": "Contract Sentinel",
  "version": "0.1",
  "description": "Deterministic hard-gate cases for XiaoBa runtime evidence contracts.",
  "source": "eval/CASE_PORTFOLIO.md#contract-sentinel",
  "decision_policy": {
    "fail_on_any_hard_failure": true,
    "fail_on_required_artifact_failure": true,
    "block_on_missing_evidence": true,
    "min_pass_rate": 1
  },
  "cases": [
    {
      "case_id": "contract.runtime-evidence.001",
      "name": "Runtime tool evidence stays observable",
      "lane": "contract_sentinel",
      "target_module": "runtime",
      "risk_level": "release_blocking",
      "task": "Verify a synthetic XiaoBa turn has parseable JSONL, complete tool result evidence, observable failures, bounded retry, and required artifact evidence.",
      "inputs": {
        "jsonl": "../fixtures/contract-sentinel/runtime-evidence.jsonl",
        "jsonl_schema": "session-log-v2",
        "artifacts_dir": "../fixtures/contract-sentinel/artifacts"
      },
      "required_artifacts": [
        {
          "path": "report.md",
          "type": "md",
          "action": "created",
          "evidence": "manifest_or_file"
        }
      ],
      "hard_verifiers": [
        {
          "id": "jsonl_parse"
        },
        {
          "id": "tool_transcript_completeness"
        },
        {
          "id": "tool_result_contract",
          "config": {
            "require_retryable": true,
            "require_duration_ms": true
          }
        },
        {
          "id": "runtime_observability"
        },
        {
          "id": "artifact_evidence"
        },
        {
          "id": "bounded_retry",
          "config": {
            "max_repeated_failures": 2
          }
        },
        {
          "id": "budget_check"
        }
      ],
      "budgets": {
        "max_turns": 2,
        "max_tool_calls": 6,
        "max_tokens": 4000
      },
      "failure_route": "runtime"
    },
    {
      "case_id": "contract.jsonl-compatibility.001",
      "name": "Session JSONL stays line-parseable",
      "lane": "contract_sentinel",
      "target_module": "state_evidence",
      "risk_level": "high",
      "task": "Verify baseline session JSONL compatibility for a minimal no-tool turn.",
      "inputs": {
        "jsonl": "../fixtures/contract-sentinel/jsonl-compatibility.jsonl",
        "jsonl_schema": "session-log-v2"
      },
      "hard_verifiers": [
        {
          "id": "jsonl_parse"
        },
        {
          "id": "budget_check"
        }
      ],
      "budgets": {
        "max_turns": 1,
        "max_tool_calls": 0,
        "max_tokens": 1000
      },
      "failure_route": "state_evidence"
    },
    {
      "case_id": "contract.state-boundary.001",
      "name": "Durable state and provider transcript stay separated",
      "lane": "contract_sentinel",
      "target_module": "state_evidence",
      "risk_level": "release_blocking",
      "task": "Verify durable session restore, working trace, provider transcript reference and visible history are declared as separate state evidence boundaries.",
      "inputs": {
        "jsonl": "../fixtures/contract-sentinel/state-boundary.jsonl",
        "jsonl_schema": "session-log-v2"
      },
      "hard_verifiers": [
        {
          "id": "jsonl_parse"
        },
        {
          "id": "state_boundary_contract",
          "config": {
            "require_visible_history": true
          }
        },
        {
          "id": "provider_transcript_normalization",
          "config": {
            "require_digest_ref": true
          }
        },
        {
          "id": "state_continuity",
          "config": {
            "required_texts": [
              "durable session",
              "working trace",
              "provider transcript reference",
              "visible history"
            ],
            "min_turns": 1
          }
        },
        {
          "id": "budget_check"
        }
      ],
      "budgets": {
        "max_turns": 1,
        "max_tool_calls": 0,
        "max_tokens": 1200
      },
      "failure_route": "state_evidence"
    },
    {
      "case_id": "contract.provider-transcript-degradation.001",
      "name": "Provider transcript degradation stays structured",
      "lane": "contract_sentinel",
      "target_module": "state_evidence",
      "risk_level": "release_blocking",
      "task": "Verify degraded provider transcript evidence keeps digest refs, explicit degradation reasons, fallback chains, blocked reasons, and raw payload storage flags.",
      "inputs": {
        "jsonl": "../fixtures/contract-sentinel/provider-transcript-degradation.jsonl",
        "jsonl_schema": "session-log-v2"
      },
      "hard_verifiers": [
        {
          "id": "jsonl_parse"
        },
        {
          "id": "provider_transcript_normalization",
          "config": {
            "require_digest_ref": true
          }
        },
        {
          "id": "provider_transcript_degradation",
          "config": {
            "min_degraded_refs": 2,
            "expected_reasons": [
              "MODEL_RATE_LIMIT",
              "PROVIDER_TIMEOUT"
            ],
            "expected_statuses": [
              "degraded",
              "blocked"
            ],
            "require_digest_ref": true,
            "require_explicit_raw_payload_storage_flags": true,
            "require_fallback_chain": true,
            "require_blocked_reason": true
          }
        },
        {
          "id": "assistant_text_contains",
          "config": {
            "texts": [
              "Provider transcript degraded",
              "digest references",
              "raw provider transcript content stayed outside the transcript ref"
            ]
          }
        },
        {
          "id": "budget_check"
        }
      ],
      "budgets": {
        "max_turns": 1,
        "max_tool_calls": 0,
        "max_tokens": 1000
      },
      "failure_route": "state_evidence"
    },
    {
      "case_id": "contract.provider-network-readiness-blocked.001",
      "name": "Provider-network readiness blocked default stays structured",
      "lane": "contract_sentinel",
      "target_module": "state_evidence",
      "risk_level": "release_blocking",
      "task": "Verify provider-network readiness defaults to blocked opt-in evidence with a self-consistent scorecard, safe evidence refs, and no user authorization burden.",
