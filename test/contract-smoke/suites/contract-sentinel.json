        {
          "path": "report.md",
          "type": "md",
          "action": "created",
          "evidence": "file"
        }
      ],
      "hard_verifiers": [
        {
          "id": "artifact_evidence"
        },
        {
          "id": "provider_network_readiness_contract",
          "config": {
            "scorecard_path": "scorecard.json",
            "allowed_decisions": [
              "pass",
              "fail",
              "blocked"
            ],
            "required_check_ids": [
              "provider_network.opt_in"
            ],
            "require_blocked_default": true
          }
        },
        {
          "id": "budget_check"
        }
      ],
      "budgets": {
        "max_turns": 0,
        "max_tool_calls": 0,
        "max_tokens": 0
      },
      "failure_route": "state_evidence"
    },
