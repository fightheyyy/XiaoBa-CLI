          }
        }
      ],
      "required_artifacts": [
        {
          "path": "pet-runtime-file-report.md",
          "type": "markdown",
          "evidence": "file"
        }
      ],
      "budgets": {
        "max_turns": 1,
        "max_tokens": 2600
      },
      "failure_route": "surface"
    }
  ]
