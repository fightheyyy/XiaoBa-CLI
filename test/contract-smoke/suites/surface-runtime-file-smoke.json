{
  "suite_id": "surface-runtime-file-smoke",
  "name": "Surface Runtime File Smoke",
  "version": "0.1.0",
  "description": "Deterministic runtime smoke for production FeishuBot and Pet file delivery evidence.",
  "source": "docs/surface/SPEC.md#contracts",
  "decision_policy": {
    "fail_on_any_hard_failure": true,
    "fail_on_required_artifact_failure": true,
    "block_on_missing_evidence": true,
    "min_pass_rate": 1
  },
  "cases": [
    {
      "case_id": "surface.feishu-runtime-file.001",
      "name": "FeishuBot event handler delivers a generated file",
      "lane": "requirement_acceptance",
      "target_module": "surface",
      "risk_level": "release_blocking",
      "task": "Drive a Feishu event through FeishuBot.onMessage, generate a report artifact, and verify send_file channel callback evidence.",
      "replay": {
        "mode": "surface_runtime",
        "surface": "feishu",
        "user_message": "@小八 generate and send a surface runtime file report via Feishu",
        "surface_event": {
          "event_id": "om_runtime_file_feishu_001",
          "event_type": "im.message.receive_v1",
          "message_ref": "feishu:message:om_runtime_file_feishu_001",
          "room_ref": "oc_runtime_file_eval",
          "user_ref": "ou_runtime_file_eval_user",
          "adapter_config": {
            "bot_open_id": "ou_runtime_file_eval_bot",
            "bot_aliases": [
              "小八",
              "xiaoba"
            ]
          },
          "raw": {
            "sender": {
              "sender_id": {
                "open_id": "ou_runtime_file_eval_user"
              }
            },
            "message": {
              "message_id": "om_runtime_file_feishu_001",
              "chat_id": "oc_runtime_file_eval",
              "chat_type": "group",
              "message_type": "text",
              "content": "{\"text\":\"@_user_1 generate and send a surface runtime file report via Feishu\"}",
              "mentions": [
                {
                  "key": "@_user_1",
                  "name": "小八",
                  "id": {
                    "open_id": "ou_runtime_file_eval_bot"
                  }
                }
              ]
            }
          }
        },
        "model_responses": [
          {
            "tool_calls": [
              {
                "id": "call-feishu-runtime-file-write",
                "name": "write_file",
                "arguments": {
                  "file_path": "feishu-runtime-file-report.md",
                  "content": "# Feishu Runtime File Report\n\nGenerated by surface runtime file smoke.\n"
                }
              },
              {
                "id": "call-feishu-runtime-file-text",
                "name": "send_text",
                "arguments": {
                  "text": "Feishu runtime file report is ready."
                }
              },
              {
                "id": "call-feishu-runtime-file-send",
                "name": "send_file",
                "arguments": {
                  "file_path": "feishu-runtime-file-report.md",
                  "file_name": "feishu-runtime-file-report.md"
                }
              }
            ],
            "usage": {
              "prompt_tokens": 980,
              "completion_tokens": 150
            }
          },
          {
            "content": "",
            "usage": {
              "prompt_tokens": 1020,
              "completion_tokens": 0
            }
          }
        ]
      },
      "hard_verifiers": [
        {
          "id": "jsonl_parse"
        },
        {
          "id": "runtime_observability"
        },
        {
          "id": "artifact_evidence",
          "config": {
            "required": [
              {
                "path": "feishu-runtime-file-report.md",
                "type": "markdown",
                "evidence": "file"
              }
            ]
          }
        },
        {
          "id": "surface_runtime_e2e",
          "config": {
            "expected_surface": "feishu",
            "expected_runtime_id": "feishu_bot_event",
            "expected_status_code": 200,
            "expected_session_key": "group:oc_runtime_file_eval",
            "expected_channel_id": "oc_runtime_file_eval",
            "required_event_types": [
              "feishu.event.received",
              "feishu.reply",
              "feishu.file"
            ],
            "user_message_contains": [
              "surface runtime file report"
            ],
            "min_visible_deliveries": 2,
            "min_file_deliveries": 1,
            "required_files": [
              "feishu-runtime-file-report.md"
            ],
            "require_file_artifacts": true
          }
        },
        {
          "id": "delivery_evidence_contract",
          "config": {
            "min_delivery_evidence": 2,
            "min_external_receipts": 3,
            "required_external_receipt_types": [
              "message",
              "upload",
              "file"
            ],
            "require_external_platform_ids": true,
            "require_delivery_tools": false,
            "require_file_artifact": true
          }
        },
        {
          "id": "budget_check",
          "config": {
            "max_tokens": 2600,
            "max_turns": 1
          }
        }
      ],
      "required_artifacts": [
        {
          "path": "feishu-runtime-file-report.md",
          "type": "markdown",
          "evidence": "file"
        }
      ],
      "budgets": {
        "max_turns": 1,
        "max_tokens": 2600
      },
      "failure_route": "surface"
    },
    {
