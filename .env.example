# .env 配置示例 - v0.1.1

# LLM provider
# OpenAI-compatible: openai
# Anthropic: anthropic
# Local Ollama: ollama
XIAOBA_LLM_PROVIDER=ollama
XIAOBA_LLM_API_BASE=http://localhost:11434
XIAOBA_LLM_API_KEY=
XIAOBA_LLM_MODEL=qwen3:8b
XIAOBA_LLM_MAX_TOKENS=1024
XIAOBA_OLLAMA_THINK=false
XIAOBA_OLLAMA_KEEP_ALIVE=30m
XIAOBA_OLLAMA_NUM_CTX=8192

# Optional provider-network readiness replay.
# Default is disabled so ordinary users are not forced through external auth.
XIAOBA_PROVIDER_NETWORK_REPLAY=false
XIAOBA_PROVIDER_NETWORK_USE_DEFAULT_CONFIG=false
XIAOBA_PROVIDER_NETWORK_PROVIDER=
XIAOBA_PROVIDER_NETWORK_API_BASE=
XIAOBA_PROVIDER_NETWORK_API_KEY=
XIAOBA_PROVIDER_NETWORK_MODEL=
XIAOBA_PROVIDER_NETWORK_TIMEOUT_MS=20000

# Local observability summary.
XIAOBA_OBSERVABILITY_LOCAL_ENABLED=true
XIAOBA_OBSERVABILITY_LOCAL_LIMIT=2000
XIAOBA_OBSERVABILITY_LOG_PROMPTS=false
XIAOBA_OBSERVABILITY_LOG_TOOL_ARGS=false
XIAOBA_OBSERVABILITY_LOG_FILE_CONTENT=false

XIAOBA_INSPECTOR_MAX_UPLOAD_BYTES=20971520

# Inspector 服务端配置（云端督察猫）
INSPECTOR_SERVER_HOST=0.0.0.0
INSPECTOR_SERVER_PORT=3800
INSPECTOR_WORKER_ENABLED=true
INSPECTOR_REPORT_FEISHU_CHAT_ID=
INSPECTOR_REMOTE_REQUIRED=false
XIAOBA_DASHBOARD_HOST=0.0.0.0
XIAOBA_API_BODY_LIMIT=50mb

# Inspector 持久化（生产建议：MySQL + 本地 case 工作目录）
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=xiaoba_inspector

# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BOT_OPEN_ID=
FEISHU_BOT_ALIASES=小八,xiaoba

# 微信
WEIXIN_TOKEN=
