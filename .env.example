# XiaoBa .env 配置示例

# LLM provider
# OpenAI-compatible: openai
# Anthropic: anthropic
# Local Ollama: ollama
XIAOBA_LLM_PROVIDER=ollama
XIAOBA_LLM_API_BASE=http://localhost:11434
XIAOBA_LLM_API_KEY=
XIAOBA_LLM_MODEL=qwen3:8b
XIAOBA_LLM_MAX_TOKENS=1024
XIAOBA_OLLAMA_THINK=false
XIAOBA_OLLAMA_KEEP_ALIVE=30m
XIAOBA_OLLAMA_NUM_CTX=8192

# Optional provider-network readiness replay.
# Default is disabled so ordinary users are not forced through external auth.
XIAOBA_PROVIDER_NETWORK_REPLAY=false
XIAOBA_PROVIDER_NETWORK_USE_DEFAULT_CONFIG=false
XIAOBA_PROVIDER_NETWORK_PROVIDER=
XIAOBA_PROVIDER_NETWORK_API_BASE=
XIAOBA_PROVIDER_NETWORK_API_KEY=
XIAOBA_PROVIDER_NETWORK_MODEL=
XIAOBA_PROVIDER_NETWORK_TIMEOUT_MS=20000

# Local observability summary.
XIAOBA_OBSERVABILITY_LOCAL_ENABLED=true
XIAOBA_OBSERVABILITY_LOCAL_LIMIT=2000
XIAOBA_OBSERVABILITY_LOG_PROMPTS=false
XIAOBA_OBSERVABILITY_LOG_TOOL_ARGS=false
XIAOBA_OBSERVABILITY_LOG_FILE_CONTENT=false

# Optional OTLP/HTTP protobuf trace export. Default is disabled.
# Metrics/log export is not enabled by this switch.
XIAOBA_OBSERVABILITY_ENABLED=false
XIAOBA_OBSERVABILITY_TRACES_EXPORTER=otlp
OTEL_SERVICE_NAME=xiaoba-cli
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# Signal-specific endpoint overrides the shared endpoint above.
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces
# URL-encode header values and separate multiple headers with commas.
# OTEL_EXPORTER_OTLP_TRACES_HEADERS=authorization=Bearer%20token

# Optional computer-use driver overrides. XiaoBa never invokes these through npx/Shell.
# Supported BrowserCat driver: agent-browser 0.31.1 native executable.
# Do not point this at the npm `.bin/agent-browser` JavaScript shim.
XIAOBA_AGENT_BROWSER_BIN=
# Optional path to the trusted Chrome-for-Testing cache used by agent-browser.
# BrowserCat never exposes the real HOME just to discover this cache.
PUPPETEER_CACHE_DIR=
# Supported GuiCat driver: Peekaboo 3.8.x on macOS 15+.
XIAOBA_PEEKABOO_BIN=

# Dashboard
XIAOBA_DASHBOARD_HOST=127.0.0.1
XIAOBA_API_BODY_LIMIT=50mb
# Optional absolute Node.js 18+ path for desktop child services.
XIAOBA_NODE_EXE=
# Preview builds keep the unverified electron-updater channel disabled by default.
XIAOBA_ENABLE_AUTO_UPDATE=false

# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BOT_OPEN_ID=
FEISHU_BOT_ALIASES=小八,xiaoba

# 微信
WEIXIN_TOKEN=
