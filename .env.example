# .env 配置示例 - v0.1.1

# AutoDev 平台配置（本地 XiaoBa Runtime / Inspector 都从这里读写 case）
AUTODEV_SERVER_URL=http://127.0.0.1:8090
AUTODEV_API_KEY=
AUTODEV_ENGINEER_POLL_INTERVAL_MS=300000
AUTODEV_ENGINEER_BATCH_SIZE=3
AUTODEV_REVIEWER_POLL_INTERVAL_MS=300000
AUTODEV_REVIEWER_BATCH_SIZE=3
AUTODEV_REVIEWER_WRITEBACK_ENABLED=true
XIAOBA_INSPECTOR_MAX_UPLOAD_BYTES=20971520
LOG_INGEST_AUTO_ENABLED=true
LOG_INGEST_AUTO_TIME=20:00
LOG_INGEST_STABLE_MINUTES=5
LOG_INGEST_AUTO_MAX_FILES=12

# Inspector 服务端配置（云端督察猫）
INSPECTOR_SERVER_HOST=0.0.0.0
INSPECTOR_SERVER_PORT=3800
INSPECTOR_WORKER_ENABLED=true
INSPECTOR_REPORT_FEISHU_CHAT_ID=
INSPECTOR_REMOTE_REQUIRED=false
XIAOBA_DASHBOARD_HOST=0.0.0.0
XIAOBA_API_BODY_LIMIT=50mb

# Inspector 持久化（生产建议：MySQL + 本地 case 工作目录）
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=xiaoba_inspector

# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BOT_OPEN_ID=
FEISHU_BOT_ALIASES=小八,xiaoba

# Cats Company
CATSCOMPANY_SERVER_URL=
CATSCOMPANY_API_KEY=
CATSCOMPANY_HTTP_BASE_URL=https://app.catsco.cc

# 微信
WEIXIN_TOKEN=
